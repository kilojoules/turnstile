\@writefile{toc}{\contentsline {paragraph}{Per-category structure depends on probe methodology.}{4}{section*.14}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Per-category compliance probe AUC under two methodologies. \emph  {Within-category}: train and 5-fold-CV-test inside one category at a time, no cross-category transfer. Wide spread (0.43--0.85). Physical harm ($0/22$ wins) and Sexual/Adult ($1/40$ wins) drop out for lack of within-category positives. \emph  {Pooled}: train one global probe on 9{,}400 conversations, evaluate per-category test folds. Compressed (0.63--0.75). The pooled probe inherits global compliance signal that masks per-category nulls. The within-category measurement is the cleaner test of category-specific representational content.}}{4}{table.caption.15}\protected@file@percent }
\newlabel{tab:per_cat_methodology}{{2}{4}{Per-category compliance probe AUC under two methodologies. \emph {Within-category}: train and 5-fold-CV-test inside one category at a time, no cross-category transfer. Wide spread (0.43--0.85). Physical harm ($0/22$ wins) and Sexual/Adult ($1/40$ wins) drop out for lack of within-category positives. \emph {Pooled}: train one global probe on 9{,}400 conversations, evaluate per-category test folds. Compressed (0.63--0.75). The pooled probe inherits global compliance signal that masks per-category nulls. The within-category measurement is the cleaner test of category-specific representational content}{table.caption.15}{}}
